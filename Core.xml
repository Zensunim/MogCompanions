<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">

  <Button name="MogCompanionsListButtonTemplate" inherits="SecureActionButtonTemplate" virtual="true">
    <Size x="100" y="24"/>
    <Layers>
      <Layer level="HIGH">
        <FontString parentKey="Name" inherits="GameTooltipText" justifyH="LEFT"><!-- GameFontNormalMed1 -->
          <Color r="1" g="1" b="1"/>
          <FontHeight>
            <AbsValue val="16"/>
          </FontHeight>
          <Anchors>
            <Anchor point="LEFT" x= "0" y="-1"/>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Scripts>
      <OnEnter>
      </OnEnter>
      <OnLeave>
      </OnLeave>
    </Scripts>    
  </Button>

  <CheckButton name="MogCompanionsMultiSelectListButtonTemplate" virtual="true">
    <Size x="100" y="24"/>
    <Layers>
      <Layer level="ARTWORK">
        <Texture parentKey="CheckboxBackground" file="Interface\Buttons\UI-CheckBox-Up">
          <Size x="18" y="18"/>
          <Anchors>
            <Anchor point="LEFT" x="0" y="0"/>
          </Anchors>
        </Texture>
        <Texture parentKey="CheckboxCheck" file="Interface\Buttons\UI-CheckBox-Check">
          <Size x="18" y="18"/>
          <Anchors>
            <Anchor point="LEFT" x="0" y="0"/>
          </Anchors>
        </Texture>
      </Layer>
      <Layer level="HIGH">
        <FontString parentKey="Name" inherits="GameTooltipText" justifyH="LEFT">
          <Color r="1" g="1" b="1"/>
          <FontHeight>
            <AbsValue val="16"/>
          </FontHeight>
          <Anchors>
            <Anchor point="LEFT" x="22" y="-1"/>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Scripts>
      <OnLoad>
        self.CheckboxCheck:Hide();
      </OnLoad>
      <OnEnter>
      </OnEnter>
      <OnLeave>
      </OnLeave>
    </Scripts>
  </CheckButton>

</Ui>
